{% extends 'base.html.twig' %}

{% block title %}Accueil — Portfolio{% endblock %}

{% block body %}
    <section class="max-w-3xl mx-auto px-6 pt-24 pb-20">
        <p class="text-sm text-ink-dim mb-4">Développeur Symfony</p>
        <h1 class="font-display text-5xl leading-[1.15] mb-6">
            Je construis des applications web claires et durables.
        </h1>
        <p class="text-ink-dim max-w-lg leading-relaxed">
            Je conçois des outils sur mesure, pensés pour être simples à utiliser et faciles à maintenir dans le temps.
        </p>
    </section>

    {% if featuredProjects|length > 0 %}
    <section class="max-w-3xl mx-auto px-6 py-16 border-t border-line">
        <h2 class="font-display text-2xl mb-10">Projets récents</h2>
        <div class="space-y-10">
            {% for project in featuredProjects %}
                <a href="{{ path('app_project_show', {slug: project.slug}) }}" class="group block">
                    <div class="flex items-baseline justify-between mb-2">
                        <h3 class="font-display text-xl group-hover:text-accent transition">{{ project.title }}</h3>
                        <span class="text-sm text-ink-dim opacity-0 group-hover:opacity-100 transition">Voir →</span>
                    </div>
                    <p class="text-ink-dim leading-relaxed">{{ project.shortDescription }}</p>
                </a>
            {% endfor %}
        </div>
    </section>
    {% endif %}

    {% if skills|length > 0 %}
    <section class="max-w-3xl mx-auto px-6 py-16 border-t border-line">
        <h2 class="font-display text-2xl mb-8">Compétences</h2>
        <div class="flex flex-wrap gap-x-6 gap-y-3 text-ink-dim">
            {% for skill in skills %}
                <span>{{ skill.name }}</span>
            {% endfor %}
        </div>
    </section>
    {% endif %}
{% endblock %}