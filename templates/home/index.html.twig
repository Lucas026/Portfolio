{% extends 'base.html.twig' %}

{% block title %}Accueil — Mon Portfolio{% endblock %}

{% block body %}
    <section class="max-w-5xl mx-auto px-6 py-24 text-center">
        <h1 class="text-5xl font-bold text-slate-900 mb-4">Salut, je suis Lucas 👋</h1>
        <p class="text-lg text-slate-600 max-w-xl mx-auto">
            Développeur passionné par le web et les projets Symfony.
        </p>
    </section>

    {% if featuredProjects|length > 0 %}
    <section class="max-w-5xl mx-auto px-6 py-16">
        <h2 class="text-2xl font-bold text-slate-900 mb-8">Projets récents</h2>
        <div class="grid md:grid-cols-3 gap-6">
            {% for project in featuredProjects %}
                <a href="{{ path('app_project_show', {slug: project.slug}) }}"
                   class="block bg-white rounded-xl border border-slate-200 overflow-hidden hover:shadow-lg transition">
                    {% if project.coverImage %}
                        <img src="{{ asset('images/' ~ project.coverImage) }}" alt="{{ project.title }}" class="w-full h-40 object-cover">
                    {% endif %}
                    <div class="p-5">
                        <h3 class="font-semibold text-slate-900 mb-1">{{ project.title }}</h3>
                        <p class="text-sm text-slate-500">{{ project.shortDescription }}</p>
                    </div>
                </a>
            {% endfor %}
        </div>
    </section>
    {% endif %}

    {% if skills|length > 0 %}
    <section class="max-w-5xl mx-auto px-6 py-16">
        <h2 class="text-2xl font-bold text-slate-900 mb-8">Compétences</h2>
        <div class="flex flex-wrap gap-3">
            {% for skill in skills %}
                <span class="px-4 py-2 bg-white border border-slate-200 rounded-full text-sm font-medium">
                    {{ skill.name }}
                </span>
            {% endfor %}
        </div>
    </section>
    {% endif %}
{% endblock %}