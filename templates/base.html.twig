<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Mon Portfolio{% endblock %}</title>
    {% block stylesheets %}
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    {% endblock %}
</head>
<body class="bg-slate-50 text-slate-800">
    <nav class="bg-white border-b border-slate-200 sticky top-0 z-50">
        <div class="max-w-5xl mx-auto px-6 py-4 flex justify-between items-center">
            <a href="{{ path('app_home') }}" class="font-bold text-lg text-slate-900">Mon Portfolio</a>
            <div class="flex gap-6 text-sm font-medium">
                <a href="{{ path('app_home') }}" class="hover:text-indigo-600 transition">Accueil</a>
                <a href="{{ path('app_project_index') }}" class="hover:text-indigo-600 transition">Projets</a>
                <a href="{{ path('app_contact') }}" class="hover:text-indigo-600 transition">Contact</a>
            </div>
        </div>
    </nav>

    <main>
        {% block body %}{% endblock %}
    </main>

    <footer class="border-t border-slate-200 mt-20 py-8 text-center text-sm text-slate-500">
        © {{ "now"|date("Y") }} — Fait avec Symfony & Tailwind
    </footer>

    {% block javascripts %}
        {{ importmap('app') }}
    {% endblock %}
</body>
</html>