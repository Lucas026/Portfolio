<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Portfolio{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600&family=Inter:wght@400;500&display=swap" rel="stylesheet">
    {% block stylesheets %}
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    {% endblock %}
</head>
<body class="bg-paper text-ink antialiased">

    <nav class="border-b border-line">
        <div class="max-w-3xl mx-auto px-6 py-6 flex justify-between items-center">
            <a href="{{ path('app_home') }}" class="font-display text-lg">DENIS Lucas</a>
            <div class="flex gap-8 text-sm text-ink-dim">
                <a href="{{ path('app_home') }}" class="hover:text-ink transition">Accueil</a>
                <a href="{{ path('app_project_index') }}" class="hover:text-ink transition">Projets</a>
                <a href="{{ path('app_contact') }}" class="hover:text-ink transition">Contact</a>
            </div>
        </div>
    </nav>

    <main>
        {% block body %}{% endblock %}
    </main>

    <footer class="border-t border-line mt-32 py-10">
        <div class="max-w-3xl mx-auto px-6 flex justify-between items-center text-sm text-ink-dim">
            <span>© {{ "now"|date("Y") }}</span>
            <span>Fait avec Symfony</span>
        </div>
    </footer>

    {% block javascripts %}
        {{ importmap('app') }}
    {% endblock %}
</body>
</html>