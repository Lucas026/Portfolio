{% extends 'base.html.twig' %}

{% block title %}Projets{% endblock %}

{% block body %}
    <section class="max-w-3xl mx-auto px-6 py-20">
        <h1 class="font-display text-4xl mb-12">Projets</h1>
        <div class="space-y-10">
            {% for project in projects %}
                <a href="{{ path('app_project_show', {slug: project.slug}) }}" class="group block border-b border-line pb-10 last:border-0">
                    <div class="flex items-baseline justify-between mb-2">
                        <h3 class="font-display text-xl group-hover:text-accent transition">{{ project.title }}</h3>
                        <span class="text-sm text-ink-dim opacity-0 group-hover:opacity-100 transition">Voir →</span>
                    </div>
                    <p class="text-ink-dim leading-relaxed">{{ project.shortDescription }}</p>
                </a>
            {% else %}
                <p class="text-ink-dim">Aucun projet pour le moment.</p>
            {% endfor %}
        </div>
    </section>
{% endblock %}