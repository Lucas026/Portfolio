{% extends 'base.html.twig' %}

{% block title %}{{ project.title }}{% endblock %}

{% block body %}
    <section class="max-w-2xl mx-auto px-6 py-20">
        <a href="{{ path('app_project_index') }}" class="text-sm text-accent hover:underline">← Retour aux projets</a>
        <h1 class="font-display text-4xl mt-6 mb-8">{{ project.title }}</h1>
        <div class="text-ink-dim leading-relaxed space-y-4">
            {{ project.content|nl2br }}
        </div>
        <div class="mt-10 flex gap-4">
            {% if project.demoUrl %}
                <a href="{{ project.demoUrl }}" target="_blank" class="px-5 py-2.5 bg-accent text-paper text-sm rounded-sm">Voir la démo</a>
            {% endif %}
            {% if project.githubUrl %}
                <a href="{{ project.githubUrl }}" target="_blank" class="px-5 py-2.5 border border-line text-sm rounded-sm">GitHub</a>
            {% endif %}
        </div>
    </section>
{% endblock %}