{% extends 'base.html.twig' %}

{% block title %}{{ project.title }}{% endblock %}

{% block body %}
    <section class="max-w-3xl mx-auto px-6 py-16">
        <a href="{{ path('app_project_index') }}" class="text-sm text-indigo-600 hover:underline">← Retour aux projets</a>
        <h1 class="text-3xl font-bold text-slate-900 mt-4 mb-6">{{ project.title }}</h1>
        <div class="prose max-w-none">
            {{ project.content|nl2br }}
        </div>

        <div class="mt-8 flex gap-4">
            {% if project.demoUrl %}
                <a href="{{ project.demoUrl }}" target="_blank" class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium">Voir la démo</a>
            {% endif %}
            {% if project.githubUrl %}
                <a href="{{ project.githubUrl }}" target="_blank" class="px-4 py-2 border border-slate-300 rounded-lg text-sm font-medium">GitHub</a>
            {% endif %}
        </div>
    </section>
{% endblock %}